using System;

class Program
{
    static void Main()
    {
        Console.WriteLine("Seleccione el tipo de vehículo:");
        Console.WriteLine("1: Bicicleta");
        Console.WriteLine("2: Motocicleta");
        Console.WriteLine("3: Auto");
        Console.WriteLine("4: Camión");
        Console.WriteLine("5: Autobús");

        Console.Write("\nIngrese el número de su opción: ");
        int opcion = int.Parse(Console.ReadLine());

        Console.WriteLine("\n--- Clasificación ---");

        // Estructura Switch para determinar la categoría
        switch (opcion)
        {
            case 1:
                Console.WriteLine("Vehículo: Bicicleta -> Clasificación: No motorizado");
                break;
            case 2:
                Console.WriteLine("Vehículo: Motocicleta -> Clasificación: Ligero");
                break;
            case 3:
                Console.WriteLine("Vehículo: Auto -> Clasificación: Mediano");
                break;
            case 4:
                Console.WriteLine("Vehículo: Camión -> Clasificación: Pesado");
                break;
            case 5:
                Console.WriteLine("Vehículo: Autobús -> Clasificación: Transporte público");
                break;
            default:
                Console.WriteLine("Opción no válida. Por favor, elija un número del 1 al 5.");
                break;
        }
    }
}
